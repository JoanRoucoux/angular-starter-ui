{
  "name": "angular-starter-ui",
  "version": "1.1.0",
  "description": "Ready-to-use Angular design system starter: a publishable component library with Storybook, ESLint, Prettier, Tailwind CSS, Vitest and Sheriff already wired up.",
  "keywords": [
    "angular",
    "design-system",
    "component-library",
    "starter",
    "template",
    "typescript",
    "storybook",
    "tailwindcss",
    "eslint",
    "prettier",
    "vitest",
    "ng-packagr",
    "sheriff"
  ],
  "homepage": "https://github.com/JoanRoucoux/angular-starter-ui#readme",
  "bugs": {
    "url": "https://github.com/JoanRoucoux/angular-starter-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoanRoucoux/angular-starter-ui.git"
  },
  "license": "MIT",
  "author": {
    "name": "Joan Roucoux",
    "email": "joan.roucoux@gmail.com"
  },
  "scripts": {
    "ng": "ng",
    "start": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "build-storybook": "storybook build",
    "test": "ng test",
    "test:coverage": "ng test --coverage",
    "test-storybook": "test-storybook",
    "test-storybook:ci": "concurrently -k -s first -n storybook,test \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && test-storybook --url http://127.0.0.1:6006\"",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "private": true,
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85",
  "lint-staged": {
    "*.{ts,html}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,scss,json,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.3",
    "@angular/animations": "^22.0.7",
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@softarc/eslint-plugin-sheriff": "^0.19.6",
    "@softarc/sheriff-core": "^0.19.6",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/addon-themes": "^10.5.3",
    "@storybook/angular-vite": "^10.5.3",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/angular": "^19.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "angular-eslint": "22.1.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-storybook": "^10.5.3",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "ng-packagr": "^22.0.1",
    "postcss": "^8.5.21",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "storybook": "^10.5.3",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  }
}
